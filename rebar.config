{erl_opts, [debug_info]}.
{deps, [
    {cowboy, "2.10.0"},
    {jsx, "3.1.0"}
]}.

{relx, [{release, {counter_release, "0.0.1"},
         [counter_app],
         [{dev_mode, false},
          {include_erts, true}]},
        {release, {counter_release, "0.1.0"},
         [counter_app],
         [{dev_mode, false}]}
       ]}.

{shell, [
    {apps, [counter_app]}
]}.
